node {
    stage('Checkout Code') {
        checkout scm
    }

    stage('Install Dependencies') {
      
        withEnv(['PATH+NPM=/usr/local/bin:/usr/bin:/bin']) { 
            dir('server') {
                sh 'npm install'
            }
        }
    }

    stage('Build') {
        dir('server') {
            sh 'npm run build'
        }
    }

    stage('Deploy') {
        dir('server') {
            sh 'pm2 delete todo-backend || true'
            sh 'pm2 start dist/index.js --name todo-backend'
            sh 'pm2 save'
        }
    }
}