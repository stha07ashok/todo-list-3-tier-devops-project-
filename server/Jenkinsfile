node {
    // In Scripted pipelines, use withEnv to set PATH variables
    withEnv(['PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin']) {
        
        stage('Checkout Code') {
            checkout scm
        }

        stage('Install Dependencies') {
            dir('server') {
                sh 'npm install'
            }
        }

        stage('Build') {
            dir('server') {
                sh 'npm run build'
            }
        }

        stage('Deploy') {
            dir('server') {
                // Ensure pm2 is accessible via the PATH set above
                sh 'pm2 delete todo-backend || true'
                sh 'pm2 start dist/index.js --name todo-backend'
                sh 'pm2 save'
            }
        }
    }
}