node {
    stage('Checkout Code') {
        checkout scm
    }

    stage('Install Dependencies') {
        dir('server') {
            // First, try to find npm, if not found, install it via apt-get (requires root/sudo)
            // If you are in a restricted container, use this to ensure npm is present:
            sh '''
                if ! command -v npm &> /dev/null; then
                    echo "npm not found, installing..."
                    apt-get update && apt-get install -y nodejs npm
                fi
                npm install
            '''
        }
    }

    stage('Build') {
        dir('server') {
            sh 'npm run build'
        }
    }

    stage('Deploy') {
        dir('server') {
            sh 'pm2 delete todo-backend || true'
            sh 'pm2 start dist/index.js --name todo-backend'
            sh 'pm2 save'
        }
    }
}